-- Get your towers
local function getMyTowers()
    local towers = {}
    local inventory = player:FindFirstChild("Inventory")
    if inventory then
        local defenses = inventory:FindFirstChild("Defenses")
        if defenses then
            for _, tower in pairs(defenses:GetChildren()) do
                table.insert(towers, tower.Name)
            end
        end
    end
    return towers
end

-- Get a tower from workspace
local function getPlacedTower()
    local workspace = game:GetService("Workspace")
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and (obj.Name:match("Cannon") or obj.Name:match("Tower")) then
            return obj.Name, obj
        end
    end
    return nil, nil
end

